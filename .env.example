# ── LLM Provider Selection ─────────────────────────────────────────────────────
# Set to 'anthropic' or 'openai'. If not set, auto-detected from which key is present.
MAI_LLM_PROVIDER=anthropic

# ── Anthropic (Claude) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Options: claude-sonnet-4-6 (recommended), claude-opus-4-8 (best quality), claude-haiku-4-5-20251001 (fastest/cheapest)
MAI_ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI (legacy) ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
MAI_OPENAI_MODEL=gpt-5.4-mini
